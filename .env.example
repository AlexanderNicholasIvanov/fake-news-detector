# Copy to .env and adjust. .env is gitignored.

# --- Postgres ---
POSTGRES_USER=fnd
POSTGRES_PASSWORD=fnd_dev_password
POSTGRES_DB=fakenews
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy URL (psycopg3 driver). Host "db" is the compose service name.
DATABASE_URL=postgresql+psycopg://fnd:fnd_dev_password@db:5432/fakenews

# --- Ollama (M2+) ---
# OUR client target. From inside a container, reach the host's Ollama via
# host.docker.internal. The Ollama *server* on the host must listen on 0.0.0.0
# (set host env var OLLAMA_HOST=0.0.0.0:11434 and restart Ollama) so the
# container can reach it.
OLLAMA_BASE_URL=http://host.docker.internal:11434
SCORING_MODEL=qwen3:14b

# --- Worker (M1+) ---
POLL_INTERVAL_MINUTES=10

# --- Frontend dev proxy (compose) ---
VITE_API_PROXY=http://api:8000
