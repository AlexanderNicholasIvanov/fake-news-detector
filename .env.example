# Copy to .env and adjust. .env is gitignored.
#
# The stack runs natively (no Docker): a locally installed PostgreSQL (with the
# pgvector extension) and the host's Ollama. All hosts are localhost.

# --- Postgres ---
POSTGRES_USER=fnd
POSTGRES_PASSWORD=fnd_dev_password
POSTGRES_DB=fakenews
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy URL (psycopg3 driver). Points at the locally installed PostgreSQL.
DATABASE_URL=postgresql+psycopg://fnd:fnd_dev_password@localhost:5432/fakenews

# --- Ollama ---
# Ollama runs on the same host. The default bind (127.0.0.1:11434) is fine for a
# native run — no need for OLLAMA_HOST=0.0.0.0 (that was only for containers).
OLLAMA_BASE_URL=http://localhost:11434
SCORING_MODEL=qwen3:14b

# --- Worker ---
POLL_INTERVAL_MINUTES=10

# The frontend (Vite dev server) proxies /api to http://localhost:8000 by default,
# so no VITE_API_PROXY is needed for a native run.
